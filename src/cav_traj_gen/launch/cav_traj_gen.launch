<?xml version="1.0"?>
<launch>

 
  <arg name="output" default="screen" /> <!-- screen/log -->
  <arg name="required" default="true" />
  <arg name="respawn" default="false" />
  <arg name="target_time" default="1" />

  <node pkg="cav_traj_gen" type="cav_traj_gen" name="cav_traj_gen" respawn="$(arg respawn)" required="$(arg required)" output="$(arg output)">
  </node>
</launch>